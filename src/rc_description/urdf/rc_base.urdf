<?xml version="1.0"?>
<robot name="rc_car">

  <!-- ========================= -->
  <!-- Base Link (실제 차체 크기) -->
  <!-- ========================= -->
  <link name="base_link">
    <visual>
      <!-- 중심을 지면 위 8.5cm -->
      <origin xyz="0 0 0.085" rpy="0 0 0"/>
      <geometry>
        <!-- 길이(X) 0.255, 가로(Y) 0.15, 높이(Z) 0.17 -->
        <box size="0.255 0.15 0.17"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.2 0.8 1.0"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0.085" rpy="0 0 0"/>
      <geometry>
        <box size="0.255 0.15 0.17"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.085"/>
      <mass value="1.0"/>
      <inertia
        ixx="0.01" ixy="0.0" ixz="0.0"
        iyy="0.01" iyz="0.0"
        izz="0.01"/>
    </inertial>
  </link>

  <!-- ========================= -->
  <!-- Laser Frame -->
  <!-- ========================= -->
  <link name="laser_frame"/>

  <!-- ========================= -->
  <!-- Fixed Joint: Base → Laser -->
  <!-- ========================= -->
  <joint name="base_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>

    <!-- 라이다 실제 높이 10.5cm -->
    <!-- base 중심(8.5cm) 기준 +2cm -->
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

</robot>