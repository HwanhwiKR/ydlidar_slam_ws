<?xml version="1.0"?>
<robot name="rc_car">

  <!-- ========================= -->
  <!-- Base Link (앞부분 라운드) -->
  <!-- ========================= -->
  <link name="base_link">

    <!-- ===== 뒤쪽 차체 (box) ===== -->
    <visual>
      <!-- 약간 뒤로 이동 -->
      <origin xyz="-0.03 0 0.085" rpy="0 0 0"/>
      <geometry>
        <!-- 길이 줄여서 앞쪽 공간 확보 -->
        <box size="0.20 0.15 0.17"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.2 0.8 1.0"/>
      </material>
    </visual>

    <!-- ===== 앞쪽 라운드 (cylinder) ===== -->
    <visual>
      <!-- 앞으로 이동 -->
      <origin xyz="0.095 0 0.085" rpy="0 1.5708 0"/>
      <geometry>
        <!-- 반원처럼 보이게 -->
        <cylinder radius="0.075" length="0.17"/>
      </geometry>
      <material name="blue"/>
    </visual>

    <!-- ===== Collision (단순 유지) ===== -->
    <collision>
      <origin xyz="0 0 0.085" rpy="0 0 0"/>
      <geometry>
        <box size="0.255 0.15 0.17"/>
      </geometry>
    </collision>

    <!-- ===== Inertial ===== -->
    <inertial>
      <origin xyz="0 0 0.085"/>
      <mass value="1.0"/>
      <inertia
        ixx="0.01" ixy="0.0" ixz="0.0"
        iyy="0.01" iyz="0.0"
        izz="0.01"/>
    </inertial>

  </link>

  <!-- ========================= -->
  <!-- Laser Frame -->
  <!-- ========================= -->
  <link name="laser_frame"/>

  <!-- ========================= -->
  <!-- Fixed Joint: Base → Laser -->
  <!-- ========================= -->
  <joint name="base_to_laser" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="0 0 0.02" rpy="0 0 0"/>
  </joint>

</robot>